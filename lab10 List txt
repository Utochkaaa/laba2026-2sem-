#include <iostream>
#include <list>
#include <algorithm>

using namespace std;

// Возвращает количество делителей числа
int countDivisors(int n) {
    if (n < 0) n = -n;
    if (n == 0) return 1;
    
    int count = 0;
    for (int i = 1; i <= n; i++) {
        if (n % i == 0) count++;
    }
    return count;
}

// Вывод списка на экран
void printList(const list<int>& lst, const string& name) {
    cout << name << ": ";
    for (int val : lst) {
        cout << val << " ";
    }
    cout << endl;
}

int main() {
    setlocale(LC_ALL, "Russian");
    
    list<int> numbers;
    int n, value;
    
    cout << "Введите количество элементов: ";
    cin >> n;
    
    cout << "Введите " << n << " чисел: ";
    for (int i = 0; i < n; i++) {
        cin >> value;
        numbers.push_back(value);
    }
    
    printList(numbers, "Исходный список");
    
    // Сортировка по количеству делителей
    numbers.sort([](int a, int b) {
        return countDivisors(a) < countDivisors(b);
    });
    
    printList(numbers, "Отсортированный список");
    
    return 0;
}
